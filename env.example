# ============================================================
#               CHAL CHITRA — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# ============================================================


# ── Server ───────────────────────────────────────────────────
PORT=8000


# ── Database ─────────────────────────────────────────────────
# MongoDB connection string (local or Atlas)
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/chal-chitra
MONGODB_URI=your_mongodb_connection_string


# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use * only in development; set explicit origins in production.
# Example: https://chalchitra.com,https://www.chalchitra.com
CORS_ORIGIN=*


# ── Access Token ─────────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=1d


# ── Refresh Token ────────────────────────────────────────────
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d


# ── Cloudinary (Media Storage) ───────────────────────────────
# https://console.cloudinary.com → Dashboard

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
